{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["bun-types"],
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@qinit/build": ["packages/build/src/index.ts"],
      "@qinit/build/*": ["packages/build/src/*"],
      "@qinit/compile": ["packages/compile/src/index.ts"],
      "@qinit/compile/*": ["packages/compile/src/*"],
      "@qinit/core": ["packages/core/src/index.ts"],
      "@qinit/core/*": ["packages/core/src/*"],
      "@qinit/engine": ["packages/engine/src/index.ts"],
      "@qinit/engine/*": ["packages/engine/src/*"],
      "@qinit/proto": ["packages/proto/src/index.ts"],
      "@qinit/proto/*": ["packages/proto/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "packages/vscode", "packages/*/tests/**/_probe_*", "packages/compile/src/browser.ts", "packages/compile/.generated", "packages/compile/types-build"]
}
