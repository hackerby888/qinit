{
  "name": "@qinit/compile",
  "version": "0.1.0",
  "description": "QPI contract compiler — TypeScript C++ subset → WASM, shared between browser IDE and qinit CLI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "bun": "./src/browser.ts",
      "types": "./src/browser.ts",
      "import": "./dist/browser.js"
    },
    "./analyzer": {
      "bun": "./src/analyzer.ts",
      "types": "./src/analyzer.ts",
      "import": "./dist/analyzer.js"
    }
  },
  "files": [
    "dist",
    "assets/qpi-ast.json",
    "README.md"
  ],
  "scripts": {
    "build": "bun bundle.mjs && tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@qinit/core": "workspace:*"
  },
  "dependencies": {
    "wabt": "1.0.39"
  }
}
