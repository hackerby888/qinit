{
  "name": "qpi-vscode",
  "displayName": "Qubic QPI",
  "description": "Standalone IntelliSense and QPI diagnostics for Qubic smart contracts.",
  "version": "0.1.0",
  "publisher": "qinit",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/hackerby888/qinit.git" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Linters"],
  "extensionDependencies": ["llvm-vs-code-extensions.vscode-clangd"],
  "main": "./dist/extension.js",
  "activationEvents": ["onLanguage:c", "onLanguage:cpp"],
  "contributes": {
    "commands": [
      { "command": "qpi.regenerateConfig", "title": "Regenerate clangd config", "category": "Qubic QPI" }
    ]
  },
  "scripts": {
    "build": "bun esbuild.mjs",
    "watch": "bun esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare:headers": "bun scripts/prepare-headers.ts",
    "package": "bun scripts/prepare-headers.ts --check && bun esbuild.mjs && vsce package --no-dependencies -o qpi-vscode.vsix",
    "gate": "bun run scripts/clangd-gate.ts",
    "test:int": "bun esbuild.mjs && vscode-test"
  },
  "devDependencies": {
    "@qinit/build": "workspace:*",
    "@qinit/compile": "workspace:*",
    "@qinit/core": "workspace:*",
    "@qinit/proto": "workspace:*",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.28.0",
    "mocha": "^10.7.0"
  }
}
