{
  "name": "qpi-vscode",
  "displayName": "Qubic QPI",
  "description": "CLion-grade IntelliSense + live QPI-rule diagnostics for Qubic dynamic contracts.",
  "version": "0.0.1",
  "publisher": "qubic",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/hackerby888/qinit.git" },
  "private": true,
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Linters"],
  "extensionDependencies": ["llvm-vs-code-extensions.vscode-clangd"],
  "main": "./dist/extension.js",
  "activationEvents": ["onLanguage:cpp", "workspaceContains:qinit.json"],
  "contributes": {
    "commands": [
      { "command": "qpi.regenerateConfig", "title": "Regenerate clangd config", "category": "Qubic QPI" },
      { "command": "qpi.build", "title": "Build contract", "category": "Qubic QPI" },
      { "command": "qpi.deploy", "title": "Deploy contract", "category": "Qubic QPI" },
      { "command": "qpi.call", "title": "Call a contract function", "category": "Qubic QPI" },
      { "command": "qpi.gen", "title": "Generate client", "category": "Qubic QPI" },
      { "command": "qpi.test", "title": "Test on an ephemeral node", "category": "Qubic QPI" },
      { "command": "qpi.up", "title": "Start node / sync toolchain", "category": "Qubic QPI" },
      { "command": "qpi.doctor", "title": "Doctor", "category": "Qubic QPI" },
      { "command": "qpi.new", "title": "New contract project", "category": "Qubic QPI" }
    ],
    "configuration": {
      "title": "Qubic QPI",
      "properties": {
        "qpi.core": {
          "type": "string",
          "default": "",
          "description": "Path to a core-lite checkout. Overrides QINIT_CORE and the snapshot synced by `qinit up`."
        },
        "qpi.qinitPath": {
          "type": "string",
          "default": "qinit",
          "description": "The `qinit` CLI used for verify/build/deploy. Defaults to `qinit` on PATH."
        }
      }
    }
  },
  "scripts": {
    "build": "bun esbuild.mjs",
    "watch": "bun esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "bun esbuild.mjs && vsce package --no-dependencies -o qpi-vscode.vsix",
    "gate": "bun run scripts/clangd-gate.ts",
    "test:int": "bun esbuild.mjs && vscode-test"
  },
  "devDependencies": {
    "@qinit/build": "workspace:*",
    "@qinit/core": "workspace:*",
    "@qinit/proto": "workspace:*",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "mocha": "^10.7.0"
  }
}
