// packages/proto/src/decode-container.ts
var NULL_INDEX = -1n;
// packages/proto/src/call.ts
function contractAddress(contractIndex) {
  const a = new Uint8Array(32);
  new DataView(a.buffer).setBigUint64(0, BigInt(contractIndex), true);
  return a;
}
async function callFunction(rpc, contractIndex, fnId, inFmt, outFmt) {
  const out = await rpc.querySmartContract(contractIndex, fnId, await encodeInput(inFmt));
  return await decodeOutput(out, outFmt);
}
async function invokeProcedure(opts) {
  const tx = await buildSignedTx(opts.seed, {
    destination: contractAddress(opts.contractIndex),
    amount: opts.amount,
    tick: opts.tick,
    inputType: opts.procId,
    payload: await encodeInput(opts.inFmt)
  });
  const r = await broadcastTx(tx.bytes, opts.rpcBase);
  const res = { ...r, txId: tx.id, tick: opts.tick };
  if (!opts.confirm)
    return res;
  const rpc = opts.rpc ?? new LiteRpc(opts.rpcBase);
  const deadline = Date.now() + (opts.confirmTimeoutMs ?? 30000);
  const sleep2 = (ms) => new Promise((s) => setTimeout(s, ms));
  for (;; ) {
    try {
      const st = await rpc.txStatus(opts.tick, tx.id);
      opts.onProgress?.({ tick: st.currentTick ?? 0, target: opts.tick });
      if (st.processed)
        return { ...res, confirmed: true, included: st.found, moneyFlew: st.moneyFlew };
    } catch {
      try {
        const ti = await rpc.tickInfo();
        const cur = ti.tick ?? 0;
        opts.onProgress?.({ tick: cur, target: opts.tick });
        if (cur > opts.tick)
          return { ...res, confirmed: false };
      } catch {}
    }
    if (Date.now() > deadline)
      return { ...res, confirmed: false };
    await sleep2(300);
  }
}
// packages/build/src/sdk-entry.ts
var ORACLE_STATUS_SUCCESS = 3;
var RPC_BASE = () => process.env.QINIT_RPC || "http://127.0.0.1:41841";
function provider() {
  return { rpcBase: RPC_BASE(), seed: process.env.QINIT_SEED || undefined, index: process.env.QINIT_CONTRACT ? Number(process.env.QINIT_CONTRACT) : undefined };
}
function rpc() {
  return new LiteRpc(RPC_BASE());
}
var sleep2 = (ms) => new Promise((r) => setTimeout(r, ms));
async function settle(ticks = 12, timeoutMs = 30000) {
  const r = rpc();
  const start = Date.now();
  const cur = async () => {
    try {
      return (await r.tickInfo()).tick ?? 0;
    } catch {
      return 0;
    }
  };
  const t0 = await cur();
  for (;; ) {
    const t = await cur();
    if (t >= t0 + ticks)
      return t;
    if (Date.now() - start > timeoutMs)
      return t;
    await sleep2(300);
  }
}
async function oraclePending(rpcBase = RPC_BASE()) {
  const r = await fetch(rpcBase + "/live/v1/dev/oracle-pending");
  if (!r.ok)
    throw new Error("oracle-pending -> " + r.status);
  const j = await r.json();
  return (j.queries ?? []).map((q) => ({ queryId: BigInt(q.queryId), slot: q.slot, interfaceIndex: q.interfaceIndex, query: new Uint8Array(Buffer.from(q.query, "base64")) }));
}
async function resolveOracle(queryId, reply, opts = {}) {
  const r = await fetch((opts.rpcBase ?? RPC_BASE()) + "/live/v1/dev/oracle-resolve", {
    method: "POST",
    headers: { "content-type": "application/json" },
    body: JSON.stringify({ queryId: queryId.toString(), reply: Buffer.from(reply).toString("base64"), status: opts.status ?? ORACLE_STATUS_SUCCESS })
  });
  if (!r.ok)
    throw new Error("oracle-resolve -> " + r.status);
  return (await r.json()).ok === true;
}
