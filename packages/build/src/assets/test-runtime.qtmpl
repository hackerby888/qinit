      return (await this.get("/live/v1/dev/funded-seed")).seed;
    } catch {
      return;
    }
  }
  fundedSeeds(limit = 32) {
    return this.get(`/live/v1/dev/funded-seeds?limit=${limit}`);
  }
  epochInfo() {
    return this.get("/live/v1/dev/epoch-info");
  }
  advanceTick(n) {
    return this.get(`/live/v1/dev/advance-tick?n=${n}`);
  }
  advanceToLast(gap = 3) {
    return this.get(`/live/v1/dev/advance-to-last?gap=${gap}`);
  }
  advanceEpoch() {
    return this.get("/live/v1/dev/advance-epoch");
  }
  setTickMs(ms) {
    return this.get(`/live/v1/dev/tick-ms?ms=${ms}`);
  }
