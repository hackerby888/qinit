{
  "name": "@qinit/engine",
  "version": "0.1.0",
  "description": "Framework-agnostic Qubic smart-contract simulation engine — deploy wasm contracts, advance ticks/epochs, call functions/procedures, read state, all in-process (browser or Node).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "bun": "./src/server.ts",
      "types": "./src/server.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun bundle.mjs && tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@qubic-lib/qubic-ts-library": "latest"
  },
  "devDependencies": {
    "@qinit/core": "workspace:*",
    "@qinit/proto": "workspace:*"
  }
}
